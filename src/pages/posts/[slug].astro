---
import { getCollection, type CollectionEntry } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import { formatDate } from '@/utils/date';
import { formatReadingTime, getReadingTime } from '@/utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sortedPosts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      number: sortedPosts.length - index,
    },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  number: number;
}

const { post, number } = Astro.props as Props;
const { Content } = await post.render();
const formattedDate = formatDate(post.data.date);
const readingTime = formatReadingTime(getReadingTime(post.body));
---

<Layout title={`${post.data.title} | arpeggio's`} description={post.data.description}>
  <article>
    <header class="post-header">
      <div class="post-top-row">
        <a href="/" class="back-link">&larr; home</a>
        <span class="post-number" aria-label={`arpeggio #${number}`}>
          #{number}
        </span>
      </div>

      <h1>{post.data.title}</h1>

      <div class="post-meta">
        <time datetime={formattedDate}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  article {
    margin-top: -1.5rem;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    width: 100%;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
  }

  .back-link,
  .post-number {
    color: var(--text-muted);
    font-family: monospace;
    font-size: 0.875rem;
  }

  .back-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .post-number {
    white-space: nowrap;
  }

  h1 {
    width: 100%;
    margin: 0;
    font-size: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    width: 100%;
    color: var(--text-muted);
  }

  .content {
    line-height: 1.8;
  }

</style>
