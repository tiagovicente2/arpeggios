---
import { getCollection } from 'astro:content';

import Layout from '../layouts/Layout.astro';
import { formatDate } from '@/utils/date';
import { formatReadingTime, getReadingTime } from '@/utils/reading-time';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const postsWithNumbers = posts.map((post, index) => ({
  post,
  number: posts.length - index,
  readingTime: formatReadingTime(getReadingTime(post.body)),
  formattedDate: formatDate(post.data.date),
}));
---

<Layout title="arpeggio's">
  <section class="intro">
    <p>Hello there! I'm Tiago.</p>
    <p>This is my space for thoughts, notes, and findings.</p>
  </section>

  <section class="posts">
    {postsWithNumbers.map(({ post, number, readingTime, formattedDate }) => (
      <a href={`/posts/${post.slug}`} class="post-item">
        <span class="post-number">arpeggio #{number}</span>
        <h2 class="post-title">{post.data.title}</h2>
        <div class="post-meta">
          <time datetime={formattedDate}>{formattedDate}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime}</span>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .intro {
    margin-bottom: 3rem;
  }

  .intro p {
    color: var(--text-muted);
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    display: block;
    padding: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .post-item:hover {
    background: var(--border);
    text-decoration: none;
  }

  .post-number {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: monospace;
  }

  .post-title {
    margin: 0.25rem 0;
    font-size: 1.25rem;
    color: var(--text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>
